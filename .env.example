APP_ENV=local
APP_PORT=8080
APP_VERSION=0.21.1-alpha.1
APP_ALLOW_MEMORY_MODE=false
DB_MAIN_DSN=postgres://postgres:postgres@localhost:5432/manga?sslmode=disable
DB_TEST_DSN=postgres://postgres:postgres@localhost:5432/manga_test?sslmode=disable
DB_MAX_CONNS=10
DB_CONNECT_TIMEOUT=5s
HTTP_SHUTDOWN_TIMEOUT=10s
STATE_SNAPSHOT_DIR=.cache/state
STATE_SNAPSHOT_INTERVAL=30s
STATE_SNAPSHOT_WRITE_THROUGH=true
AUTH_ACCESS_TOKEN_SECRET=local-dev-access-secret
AUTH_ACCESS_TOKEN_ISSUER=novascans-api
AUTH_EXPOSE_SENSITIVE_TOKENS=false
AUTH_LOGIN_FAILED_ATTEMPT_LIMIT_PER_MINUTE=5
AUTH_LOGIN_COOLDOWN_SECONDS=300
AUTH_EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
PAYMENT_CALLBACK_SIGNING_SECRET=local-dev-payment-callback-secret
PAYMENT_CALLBACK_TIMESTAMP_SKEW=5m