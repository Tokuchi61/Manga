APP_ENV=local
APP_PORT=8080
APP_VERSION=0.19.0-alpha.1
DB_MAIN_DSN=postgres://postgres:postgres@localhost:5432/manga?sslmode=disable
DB_TEST_DSN=postgres://postgres:postgres@localhost:5432/manga_test?sslmode=disable
DB_MAX_CONNS=10
DB_CONNECT_TIMEOUT=5s
HTTP_SHUTDOWN_TIMEOUT=10s
STATE_SNAPSHOT_DIR=.cache/state
STATE_SNAPSHOT_INTERVAL=5s
AUTH_LOGIN_FAILED_ATTEMPT_LIMIT_PER_MINUTE=5
AUTH_LOGIN_COOLDOWN_SECONDS=300
AUTH_EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60


